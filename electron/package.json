{
  "name": "lavoz-worker-installer",
  "version": "1.0.0",
  "description": "Instalador del worker de La Voz de la Verdad",
  "author": "La Voz de la Verdad",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "tsc --watch & electron .",
    "build:ts": "tsc && node scripts/copy-ui.js",
    "build": "pnpm run build:ts && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win --x64",
    "clean:service": "sc stop LaVozWorker & sc delete LaVozWorker & echo done"
  },
  "build": {
    "appId": "com.lavozverdad.worker",
    "productName": "La Voz de la Verdad - Worker",
    "copyright": "La Voz de la Verdad",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "../resources",
      "output": "dist"
    },
    "files": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "dist-electron/**/*",
          "package.json",
          "!**/*.map",
          "!**/*.ts",
          "!**/*.md",
          "!**/*.log"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../worker/dist",
        "to": "worker-dist"
      },
      {
        "from": "../resources/bins/node.exe",
        "to": "bins/node.exe"
      },
      {
        "from": "../resources/bins/yt-dlp.exe",
        "to": "bins/yt-dlp.exe"
      },
      {
        "from": "../resources/bins/WinSW.exe",
        "to": "bins/WinSW.exe"
      },
      {
        "from": "../resources/bins/ffmpeg.exe",
        "to": "bins/ffmpeg.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "executableName": "LaVozWorkerInstaller",
      "icon": "../resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "../resources/icon.ico",
      "uninstallerIcon": "../resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "La Voz Worker"
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.2"
  }
}