{
  "name": "lavoz-worker-installer",
  "version": "1.0.0",
  "description": "Instalador del worker de La Voz de la Verdad",
  "author": "La Voz de la Verdad",
  "main": "src/main.ts",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "tsc --watch & electron .",
    "build:ts": "tsc",
    "build": "tsc && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win --x64",
    "clean:service": "sc stop LaVozWorker & sc delete LaVozWorker & echo done"
  },
  "build": {
    "appId": "com.lavozverdad.worker",
    "productName": "La Voz de la Verdad - Worker",
    "copyright": "La Voz de la Verdad",
    "directories": {
      "buildResources": "../resources",
      "output": "dist"
    },
    "files": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "src/**/*",
          "package.json"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../worker/dist",
        "to": "worker-dist"
      },
      {
        "from": "../worker/node_modules",
        "to": "worker-dist/node_modules"
      },
      {
        "from": "../worker/package.json",
        "to": "worker-dist/package.json"
      },
      {
        "from": "../resources/node/node.exe",
        "to": "bins/node.exe"
      },
      {
        "from": "../resources/yt-dlp/yt-dlp.exe",
        "to": "bins/yt-dlp.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "../resources/icon.ico",
      "uninstallerIcon": "../resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "La Voz Worker"
    }
  },
  "dependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "electron": "^42.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^6.0.3"
  }
}