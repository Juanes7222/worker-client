# ─── Servidor central ───────────────────────────────────────────
SERVER_WS_URL=wss://url/workers
WORKER_ID=worker-pc-estudio
WORKER_NAME=PC Estudio Principal
WORKER_SECRET=cambia_esto_por_un_secreto_largo

# ─── Procesamiento ───────────────────────────────────────────────
WORKER_MAX_CONCURRENT_JOBS=1
MAX_VIDEO_DURATION_SECONDS=600
TEMP_DOWNLOAD_DIR=C:\Users\TuUsuario\AppData\Local\LaVozWorker\temp

# ─── AzuraCast ──────────────────────────────────────────────────
AZURACAST_BASE_URL=https://url_de_azuracast
AZURACAST_API_KEY=tu_api_key_de_azuracast
AZURACAST_STATION_ID=1
AZURACAST_PLAYLIST_ID=12